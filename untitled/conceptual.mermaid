classDiagram
    class Миссия {
        +идентификатор
        +дата
        +место
        +результат
        +стоимость_ущерба
        +комментарий
    }

    class Проклятие {
        +название
        +уровень_угрозы
    }

    class Маг {
        +имя
        +ранг
    }

    class Техника {
        +название
        +тип
        +владелец
        +урон
    }

    class Парсер {
        <<abstract>>
        +определить_формат()
        +извлечь_данные()
    }

    class XMLПарсер

    class JSONПарсер

    class TXTПарсер

    class ФабрикаПарсеров {
        +выбрать_парсер()
    }

    class ИнтерфейсПользователя {
        +путь_к_файлу
        +область_результата
    }

    Миссия "1" *-- "1" Проклятие
    Миссия "1" *-- "0..*" Маг
    Миссия "1" *-- "0..*" Техника

    Парсер <|-- XMLПарсер
    Парсер <|-- JSONПарсер
    Парсер <|-- TXTПарсер

    ФабрикаПарсеров --> Парсер

    ИнтерфейсПользователя ..> ФабрикаПарсеров
    ИнтерфейсПользователя ..> Миссия
    ИнтерфейсПользователя ..> Парсер